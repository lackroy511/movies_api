ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token


# Shared secret for issuing and verifying JWT tokens
# generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# This value should be "True" for production and "False" for local run
COOKIE_SECURE=

FRONTEND_URL=

ADMIN_EMAIL=admin@admin.com
# set strong password / generate with: python -c "import secrets; print(secrets.token_urlsafe(12))"
ADMIN_PASSWORD=
