POSTGRES_DB=auth_database
POSTGRES_USER=app
# set strong password
POSTGRES_PASSWORD=
PGDATA=/var/lib/postgresql/data/auth_database
DB_HOST=auth_database
DB_PORT=5432

LOG_LEVEL=INFO

REDIS_BASE_URL=redis://auth_redis:6379
REDIS_CACHE_TTL=300

ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=30


OTEL_TRACES_SAMPLER=parentbased_traceidratio
# How many requests should be traced
OTEL_TRACES_SAMPLER_ARG=0.25
JAEGER_SERVICE_NAME=auth_api
JAEGER_TRACER_PATH=http://jaeger-collector:4318/v1/traces
